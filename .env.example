POSTGRES_USER=jukebox
POSTGRES_PASSWORD=jukebox
POSTGRES_DB=jukebox

# ホストから直接DBへ接続する必要がある場合だけ上書きする（Prisma Studioなど）
# docker-compose.ymlの `ports` もコメント解除する必要あり
# DATABASE_URL=postgresql://jukebox:jukebox@localhost:5433/jukebox?schema=public

NEXT_PUBLIC_APP_URL=http://localhost:3000

# ルーム数の上限（未設定なら 100）。外部公開時の DoS 緩和用ソフトリミット。
# MAX_ROOMS_TOTAL=100

# 1ルームあたりのトラック上限（未設定なら 1000）。荒らし対策で絞る用途。
# MAX_TRACKS_PER_ROOM=1000
