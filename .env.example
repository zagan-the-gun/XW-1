POSTGRES_USER=jukebox
POSTGRES_PASSWORD=jukebox
POSTGRES_DB=jukebox

# ホストから直接DBへ接続する必要がある場合だけ上書きする（Prisma Studioなど）
# docker-compose.ymlの `ports` もコメント解除する必要あり
# DATABASE_URL=postgresql://jukebox:jukebox@localhost:5433/jukebox?schema=public

NEXT_PUBLIC_APP_URL=http://localhost:3000

# ルーム数の上限（未設定なら 100）。外部公開時の DoS 緩和用ソフトリミット。
# MAX_ROOMS_TOTAL=100

# 1ルームあたりのトラック上限（未設定なら 1000）。荒らし対策で絞る用途。
# MAX_TRACKS_PER_ROOM=1000

# CSRF / Socket.io CORS の許可オリジン（カンマ区切り）。
# REST の Origin/Referer 検証と Socket.io ハンドシェイクの origin 制限に使う。
# 未設定時は「リクエスト Host 自身」のみを許容するので、本番デプロイ時は必ず設定する。
# 例: ALLOWED_ORIGINS=https://app.example.com,https://staging.example.com
# ALLOWED_ORIGINS=

# Cookie に Secure 属性を付けるか。"true" / "false" で明示優先。
# 未設定なら NODE_ENV=production を真値として扱う（ローカル http 開発で誤って付けないため）。
# COOKIE_SECURE=

# /api/rooms/[slug]/auth のブルートフォース緩和用レートリミット（IP+slug 単位）。
# - WINDOW 秒以内に MAX 回 401 失敗 → LOCK 秒間 429 を返す
# - 成功すれば即時カウンタリセット
# - 400（フォーマット違反）はカウントされない
# - x-forwarded-for / x-real-ip が無い（dev 環境）場合はレートリミット自体を skip
# AUTH_RATE_LIMIT_MAX=5
# AUTH_RATE_LIMIT_WINDOW_SEC=300
# AUTH_RATE_LIMIT_LOCK_SEC=900
